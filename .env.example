# =====================================================================
# SYNK-IA · Variables de entorno (plantilla)
# ---------------------------------------------------------------------
# Copia este archivo a ".env" y rellena los valores reales.
# NUNCA subas el archivo ".env" al repositorio (ya está en .gitignore).
# =====================================================================

# ---------------------------------------------------------------------
# BACKEND / SDK — Núcleo de la aplicación
# El frontend se comunica con el backend de servicios mediante este App ID.
# ---------------------------------------------------------------------
VITE_APP_ID="6909eb511f749a49b63df48c"
# (Opcional) Endpoint personalizado de la API del backend
VITE_API_URL=""

# ---------------------------------------------------------------------
# REVO XEF — Integración TPV / Punto de venta del restaurante
# Sincronización del menú (categorías COMIDA y BEBIDA), ventas y stock.
# ---------------------------------------------------------------------
REVO_XEF_USERNAME="chickenpalaceibiza2"
REVO_XEF_PASSWORD="********"
REVO_XEF_API_URL="https://api.revoxef.works"

# ---------------------------------------------------------------------
# GMAIL / EMAIL INTELIGENTE — Buzón corporativo y triaje con IA
# ---------------------------------------------------------------------
GMAIL_ACCOUNT="info@chickenpalace.es"
GMAIL_OAUTH_CLIENT_ID=""
GMAIL_OAUTH_CLIENT_SECRET=""
GMAIL_OAUTH_REFRESH_TOKEN=""

# ---------------------------------------------------------------------
# WHATSAPP — Notificaciones y confirmación de pedidos online
# ---------------------------------------------------------------------
WHATSAPP_PHONE_NUMBER=""
WHATSAPP_API_TOKEN=""
WHATSAPP_BUSINESS_ACCOUNT_ID=""

# ---------------------------------------------------------------------
# ALMACENAMIENTO S3 — Documentos, facturas, albaranes y adjuntos
# ---------------------------------------------------------------------
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="eu-west-1"
S3_BUCKET_NAME=""

# ---------------------------------------------------------------------
# IA / LLM — Motor de agentes inteligentes y auto-procesamiento
# ---------------------------------------------------------------------
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""

# ---------------------------------------------------------------------
# BASE DE DATOS (si se usa backend propio en lugar del backend gestionado)
# ---------------------------------------------------------------------
DATABASE_URL="postgresql://usuario:password@host:5432/synkia"

# ---------------------------------------------------------------------
# ENTORNO
# ---------------------------------------------------------------------
NODE_ENV="development"
