// =====================================================================
// SYNK-IA · Esquema de base de datos (Prisma + PostgreSQL)
// ---------------------------------------------------------------------
// Modela el sistema de pedidos online (pedir.sinkialabs.com) y el
// catálogo de productos sincronizado con Revo XEF (TPV).
// =====================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────
// Catálogo de productos (sincronizado con Revo XEF)
// ─────────────────────────────────────────────────────────────
model Product {
  id          String      @id @default(cuid())
  externalId  String?     @unique // ID del producto en Revo XEF
  name        String
  description String?
  price       Decimal     @db.Decimal(10, 2)
  image       String?
  category    String
  family      MenuFamily  @default(COMIDA)
  active      Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  orderItems  OrderItem[]

  @@index([category])
  @@index([active])
}

// ─────────────────────────────────────────────────────────────
// Pedidos online
// ─────────────────────────────────────────────────────────────
model Order {
  id              String       @id @default(cuid())
  reference       String       @unique // referencia legible (p.ej. CP-000123)
  customerName    String
  customerPhone   String
  pickupTime      String?      // hora de recogida deseada
  notes           String?
  total           Decimal      @db.Decimal(10, 2)
  status          OrderStatus  @default(PENDING)
  channel         OrderChannel @default(WEB)
  whatsappSentAt  DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  items           OrderItem[]

  @@index([status])
  @@index([createdAt])
}

model OrderItem {
  id          String   @id @default(cuid())
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId     String
  product     Product? @relation(fields: [productId], references: [id])
  productId   String?
  name        String   // snapshot del nombre en el momento del pedido
  unitPrice   Decimal  @db.Decimal(10, 2)
  quantity    Int      @default(1)

  @@index([orderId])
}

enum MenuFamily {
  COMIDA
  BEBIDA
}

enum OrderStatus {
  PENDING     // pendiente de confirmación
  CONFIRMED   // confirmado
  PREPARING   // en preparación (cocina)
  READY       // listo para recoger
  COMPLETED   // entregado
  CANCELLED   // cancelado
}

enum OrderChannel {
  WEB
  WHATSAPP
  PHONE
  IN_STORE
}
